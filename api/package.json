{
  "name": "scrapstack-api",
  "version": "1.0.0",
  "description": "",
  "main": "api.js",
  "type": "module",
  "directories": {},
  "scripts": {
    "build": "esbuild source/lambda.ts --bundle --platform=node --format=cjs --outfile=out/lambda.cjs",
    "docs": "tsc source/docs.ts --outDir out-tsc --module ESNext --esModuleInterop --moduleResolution node",
    "dev": "concurrently \"tsc source/local.ts --outDir out-dev --module ESNext --esModuleInterop --moduleResolution node -watch\" \"node --watch out-dev/local\"",
    "deploy": "npm run build && npm run docs && cd ../terraform && terraform apply -var-file dev_variables.tfvars",
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "patch-package"
  },
  "author": "Scapsters",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.879.0",
    "@trpc/client": "^11.5.0",
    "@trpc/server": "^11.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "esbuild": "^0.25.9",
    "mongodb": "^6.19.0",
    "openapi-trpc": "^0.2.1",
    "status-code-enum": "^1.0.0",
    "swagger-ui-dist": "^5.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/cors": "^2.8.19",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "patch-package": "^8.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
